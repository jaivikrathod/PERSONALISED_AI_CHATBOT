# ----------------------------------------------------------------------------
# Environment configuration. Copy to ".env" and fill in real values.
# Never commit the real .env file.
# ----------------------------------------------------------------------------

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL + pgvector) ---
DB_NAME=ai_support
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Redis (Celery broker + Channels layer) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- LLM / Embedding providers ---
# Which provider the abstraction layer should use:
#   embeddings: minilm (local, key-free) | openai | gemini
#   llm:        local  (extractive, key-free) | openai | gemini
EMBEDDING_PROVIDER=minilm
LLM_PROVIDER=local

# Vector dimension MUST match the embedding model output.
# minilm all-MiniLM-L6-v2 -> 384 ; openai text-embedding-3-small -> 1536 ;
# gemini text-embedding-004 -> 768
EMBEDDING_DIM=384

# Sentence-Transformers model for the local (minilm) embedding provider.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=...
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash

# --- Chatbot behaviour ---
# Below this cosine similarity the bot escalates to a human agent.
# MiniLM paraphrase scores sit lower than OpenAI's; 0.5 is a good default.
CHAT_CONFIDENCE_THRESHOLD=0.5
CHAT_TOP_K=3
